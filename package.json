{
  "name": "agile-tools",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:contract": "vitest run --config tests/contract/vitest.config.ts",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:e2e": "playwright test",
    "test:perf": "vitest run --config tests/integration/performance/vitest.config.ts",
    "dev": "pnpm -r --parallel dev"
  },
  "devDependencies": {
    "@agile-tools/db": "workspace:*",
    "@agile-tools/jira-client": "workspace:*",
    "@agile-tools/shared": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "agent-browser": "^0.27.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "msw": "^2.13.4",
    "testcontainers": "^11.14.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "@react-spring/web": "^10.0.3",
      "postcss": "8.5.10"
    }
  }
}
